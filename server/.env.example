# MongoDB Connection (use local or Atlas)
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/campus-marketplace
# Option 2: MongoDB Atlas (replace with your own URI)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/campus-marketplace

# JWT Secret (change this to any random string)
JWT_SECRET=campus-marketplace-secret-key-change-this-2026

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
